# Spredd API
SPREDD_API_URL=https://api.spredd.com
SPREDD_API_KEY=your_spredd_api_key

# TinyFish Web Agent API
TINYFISH_API_URL=https://api.tinyfish.ai
TINYFISH_API_KEY=your_tinyfish_api_key

# Google Gemini (for AI context generation)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Tokens API (optional, crypto market enrichment)
TOKENS_API_URL=https://api.tokens.xyz
TOKENS_API_KEY=your_tokens_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
B4E_ADMIN_KEY=bk_admin_your_secret_key_here
B4E_BETA=true

# DFlow API (optional, for direct Kalshi market lookup on Solana)
DFLOW_API_KEY=your_dflow_api_key

# Auth (Turso database)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token
JWT_SECRET=your_random_64_char_secret

# Email (Resend)
RESEND_API_KEY=re_your_resend_key

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_LITE_PRICE_ID=price_your_lite_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_your_stripe_key

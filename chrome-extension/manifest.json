{
  "manifest_version": 3,
  "name": "before - Prediction Market Context",
  "version": "1.3.0",
  "description": "AI-powered context briefs for any prediction market. Know before it matters.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://polymarket.com/*",
    "https://www.polymarket.com/*",
    "https://limitless.exchange/*",
    "https://www.limitless.exchange/*",
    "https://dflow.net/*",
    "https://www.dflow.net/*",
    "https://app.dflow.net/*",
    "https://kalshi.com/*",
    "https://www.kalshi.com/*",
    "https://matchr.xyz/*",
    "https://www.matchr.xyz/*",
    "https://app.matchr.xyz/*",
    "https://polynance.ag/*",
    "https://www.polynance.ag/*",
    "https://metamask.io/prediction-markets*",
    "https://portfolio.metamask.io/*",
    "https://alphaarcade.com/*",
    "https://www.alphaarcade.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://polymarket.com/*",
        "https://www.polymarket.com/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/polymarket.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://limitless.exchange/*",
        "https://www.limitless.exchange/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/limitless.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://dflow.net/*",
        "https://www.dflow.net/*",
        "https://app.dflow.net/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/dflow.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://kalshi.com/*",
        "https://www.kalshi.com/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/kalshi.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://matchr.xyz/*",
        "https://www.matchr.xyz/*",
        "https://app.matchr.xyz/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/matchr.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://polynance.ag/*",
        "https://www.polynance.ag/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/polynance.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://metamask.io/prediction-markets*",
        "https://portfolio.metamask.io/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/metamask.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://alphaarcade.com/*",
        "https://www.alphaarcade.com/*"
      ],
      "js": ["content-scripts/widget.js", "content-scripts/alphaarcade.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
